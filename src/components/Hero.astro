---
import { Image } from 'astro:assets';
import products from '../data/products.json';

const p = products.zaklad;
---

<section class="relative bg-brand-black text-brand-white overflow-hidden min-h-screen flex flex-col justify-center px-5 py-16 md:py-24">
  <!-- Dekorativní background prvky -->
  <div class="absolute inset-0 opacity-5 pointer-events-none">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-brand-pink blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-brand-wine blur-3xl"></div>
  </div>

  <div class="relative max-w-5xl mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
    <!-- Levý sloupec: text -->
    <div>
      <!-- Badge + hodnocení -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <div class="inline-flex items-center gap-2 bg-brand-wine text-brand-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
          <span>🔥</span>
          <span>16+ · Česká hra</span>
        </div>
        <div class="inline-flex items-center gap-1.5 text-sm text-gray-300">
          <span class="text-yellow-400 text-base leading-none">★★★★★</span>
          <span class="font-bold text-brand-white">{p.hodnoceni}/5</span>
          <span class="text-gray-500">({p.pocetRecenzi} recenzí)</span>
        </div>
      </div>

      <!-- Headline -->
      <h1 class="font-display text-5xl md:text-7xl uppercase leading-none mb-4 text-brand-white">
        Hra,&nbsp;kterou si<br />
        <span class="text-brand-pink">nezahraješ</span><br />
        s babičkou
      </h1>

      <!-- Tagline -->
      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-md">
        {p.tagline}
      </p>

      <!-- Cena + CTA -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div>
          <p class="text-sm text-gray-400 uppercase tracking-wide">Základní hra</p>
          <p class="text-4xl font-display text-brand-white">{p.cena}&nbsp;{p.mena}</p>
        </div>
        <a
          href={p.addToCartUrl}
          rel="noopener"
          class="inline-block bg-brand-pink text-brand-white font-bold text-lg px-8 py-4 rounded-full hover:bg-pink-600 active:scale-95 transition-all duration-150 shadow-lg shadow-pink-500/30 focus:outline-none focus:ring-4 focus:ring-brand-pink/50"
          aria-label={`Přidat ${p.nazev} do košíku`}
        >
          Do košíku 🛒
        </a>
      </div>

      <!-- Vlastnosti -->
      <ul class="mt-6 space-y-1.5">
        {p.vlastnosti.map((v) => (
          <li class="flex items-start gap-2 text-sm text-gray-400">
            <span class="text-brand-pink mt-0.5 flex-shrink-0">✓</span>
            <span>{v}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Pravý sloupec: packshot -->
    <div class="flex justify-center">
      <img
        src={p.foto}
        alt={p.nazev}
        width="480"
        height="480"
        loading="eager"
        decoding="async"
        class="w-full max-w-xs md:max-w-sm rounded-card object-contain drop-shadow-2xl"
        onerror={`this.src='${p.fotoFallback}'`}
      />
    </div>
  </div>
</section>
