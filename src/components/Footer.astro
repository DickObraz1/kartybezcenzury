---
const year = new Date().getFullYear();
---

<footer class="bg-brand-black text-gray-400 px-5 py-10">
  <div class="max-w-2xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Branding -->
      <div>
        <p class="font-display text-brand-white text-xl uppercase mb-2">DickObraz</p>
        <p class="text-sm">Věci, které by tvoje babička asi neschválila.</p>
        <!-- PLACEHOLDER: logo DickObraz – dodat -->
      </div>

      <!-- Odkazy -->
      <div>
        <p class="text-brand-white text-sm font-bold uppercase tracking-wide mb-3">Eshop</p>
        <ul class="space-y-2 text-sm">
          <li><a href="https://www.dickobraz.cz" target="_blank" rel="noopener noreferrer" class="hover:text-brand-pink transition-colors">dickobraz.cz</a></li>
          <li><a href="https://www.dickobraz.cz/p/karty-proti-lidskosti" target="_blank" rel="noopener noreferrer" class="hover:text-brand-pink transition-colors">Karty bez cenzury</a></li>
          <!-- PLACEHOLDER: odkaz na rozšíření -->
          <li><a href="#" class="hover:text-brand-pink transition-colors">Rozšíření</a></li>
        </ul>
      </div>

      <!-- Právní + sociální sítě -->
      <div>
        <p class="text-brand-white text-sm font-bold uppercase tracking-wide mb-3">Informace</p>
        <ul class="space-y-2 text-sm">
          <li><a href="https://www.dickobraz.cz/info/obchodni-podminky" target="_blank" rel="noopener noreferrer" class="hover:text-brand-pink transition-colors">Obchodní podmínky</a></li>
          <li><a href="https://www.dickobraz.cz/info/ochrana-osobnich-udaju" target="_blank" rel="noopener noreferrer" class="hover:text-brand-pink transition-colors">Ochrana osobních údajů</a></li>
          <!-- PLACEHOLDER: sociální sítě DickObraz -->
          <li><a href="#" class="hover:text-brand-pink transition-colors">Instagram</a></li>
          <li><a href="#" class="hover:text-brand-pink transition-colors">Facebook</a></li>
        </ul>
      </div>
    </div>

    <!-- 16+ disclaimer + copyright -->
    <div class="border-t border-gray-800 pt-6 text-xs text-gray-600 space-y-2">
      <p>
        <strong class="text-gray-500">🔞 16+ obsah.</strong> Hra obsahuje dospělý humor a vulgární obsah. Není vhodná pro osoby mladší 16 let.
      </p>
      <p>
        © {year} DickObraz · Všechna práva vyhrazena · <a href="https://www.dickobraz.cz" class="hover:text-brand-pink transition-colors">dickobraz.cz</a>
      </p>
    </div>
  </div>
</footer>
