---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Stránka nenalezena — Karty bez cenzury"
  description="Tahle stránka neexistuje. Ale naše karty ano. Vrať se a kup si je."
>
  <section class="min-h-screen bg-brand-black text-brand-white flex flex-col items-center justify-center px-5 text-center">
    <p class="font-display text-8xl md:text-9xl text-brand-pink leading-none mb-4 select-none">404</p>
    <h1 class="font-display text-4xl md:text-5xl uppercase leading-none mb-4">
      Tahle stránka<br />
      <span class="text-brand-pink">neexistuje</span>
    </h1>
    <p class="text-gray-400 text-lg mb-8 max-w-sm">
      Asi ses ztratil. Ale karty tu máme. Vrať se domů a kup si je.
    </p>
    <a
      href="/"
      class="inline-block bg-brand-pink text-brand-white font-bold text-lg px-8 py-4 rounded-full hover:bg-pink-600 active:scale-95 transition-all duration-150 shadow-lg shadow-pink-500/30 focus:outline-none focus:ring-4 focus:ring-brand-pink/50"
    >
      Zpátky domů 🏠
    </a>
  </section>
</Layout>
