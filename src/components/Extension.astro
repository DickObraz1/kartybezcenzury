---
import products from '../data/products.json';

const p = products.rozsireni;
---

<section class="bg-brand-black text-brand-white py-16 md:py-24 px-5 reveal">
  <div class="max-w-2xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-brand-wine text-brand-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
      <span>🆕</span>
      <span>Rozšíření</span>
    </div>

    <div class="md:grid md:grid-cols-2 md:gap-12 md:items-center">
      <!-- Text -->
      <div>
        <h2 class="font-display text-4xl md:text-5xl uppercase leading-none mb-3">
          {p.nazev.split(':')[1]?.trim() ?? p.nazev}
        </h2>
        <p class="text-brand-pink font-bold text-lg mb-4 italic">„{p.tagline}"</p>

        <p class="text-gray-300 mb-5">
          {p.popisKratky}
        </p>

        <!-- Spolupráce badge -->
        <div class="bg-gray-900 border border-gray-700 rounded-xl p-3 mb-5 text-sm text-gray-300">
          🩺 <span class="text-brand-white font-semibold">Odborná spolupráce:</span> {p.spoluprace}
        </div>

        <!-- Obsah -->
        <ul class="space-y-2 mb-5">
          {[
            `${p.obsah.otazky} nových černých otázkových karet`,
            `${p.obsah.odpovedi} nových bílých odpovědních karet`,
            '100% kompatibilní se základní hrou',
            'Ještě méně vhodné pro slušnou společnost',
          ].map((item) => (
            <li class="flex gap-3 text-gray-300 text-sm">
              <span class="text-brand-pink flex-shrink-0">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <!-- Varování: vyžaduje základní hru -->
        <div class="bg-brand-wine/20 border border-brand-wine/40 rounded-xl px-4 py-3 mb-6 text-sm text-gray-300">
          ⚠️ {p.vyzaduje}
        </div>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div>
            <p class="text-sm text-gray-400 uppercase tracking-wide">Rozšíření</p>
            <p class="text-3xl font-display">{p.cena} {p.mena}</p>
          </div>
          <a
            href={p.addToCartUrl}
            rel="noopener"
            class="inline-block bg-brand-wine text-brand-white font-bold px-7 py-3.5 rounded-full hover:bg-red-900 active:scale-95 transition-all duration-150 focus:outline-none focus:ring-4 focus:ring-brand-wine/50"
            aria-label={`Přidat ${p.nazev} do košíku`}
          >
            Přidat rozšíření 🛒
          </a>
        </div>
      </div>

      <!-- Fotka rozšíření -->
      <div class="mt-10 md:mt-0 flex justify-center">
        <img
          src={p.foto}
          alt={p.nazev}
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full max-w-xs rounded-card object-contain drop-shadow-2xl"
          onerror={`this.src='${p.fotoFallback}'`}
        />
      </div>
    </div>
  </div>
</section>
