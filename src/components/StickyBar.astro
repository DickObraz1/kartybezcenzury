---
import products from '../data/products.json';

const p = products.zaklad;
---

<div
  id="sticky-bar"
  class="fixed bottom-0 left-0 right-0 z-50 bg-brand-black border-t border-gray-800 px-5 py-3 translate-y-full transition-transform duration-300"
  aria-label="Rychlý nákup"
>
  <div class="max-w-5xl mx-auto flex items-center justify-between gap-3">
    <div>
      <p class="text-xs text-gray-400 leading-none">{p.nazev.split('–')[0].trim()}</p>
      <p class="text-xl font-display text-brand-white">{p.cena} {p.mena}</p>
    </div>

    <a
      href={p.addToCartUrl}
      rel="noopener"
      data-ga-product="zaklad"
      class="bg-brand-pink text-brand-white font-bold px-6 py-3 rounded-full text-base hover:bg-pink-600 active:scale-95 transition-all duration-150 whitespace-nowrap focus:outline-none focus:ring-4 focus:ring-brand-pink/50"
      aria-label={`Přidat ${p.nazev} do košíku`}
    >
      Do košíku 🛒
    </a>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-bar');
  const hero = document.querySelector('section');

  if (bar && hero) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          bar.classList.remove('translate-y-full');
        } else {
          bar.classList.add('translate-y-full');
        }
      },
      { threshold: 0 }
    );
    observer.observe(hero);
  }
</script>
