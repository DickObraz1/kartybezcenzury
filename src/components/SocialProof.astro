---
import products from '../data/products.json';

const p = products.zaklad;

const reviews = [
  {
    name: 'Karolína',
    stars: 5,
    text: 'Doporučuji hrát ve skupince přátel, kde se chcete zbavit lidí, co nemají váš humor.',
  },
  {
    name: 'Jan Klimeš',
    stars: 5,
    text: 'Konečně dobrá a vtipná karetní hra na párty, která se neomrzí. Doporučuji :)',
  },
  {
    name: 'Kristýna Novotná',
    stars: 5,
    text: 'Vtipné, originální karty plné nekorektnosti – prostě jak název vypovídá, bez cenzury!',
  },
];
---

<section class="bg-brand-white py-16 md:py-24 px-5 reveal">
  <div class="max-w-2xl mx-auto">
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 mb-12 text-center">
      <div class="bg-brand-gray rounded-card p-4">
        <p class="font-display text-3xl md:text-4xl text-brand-black">1 000+</p>
        <p class="text-xs text-brand-gray-dark uppercase tracking-wide mt-1">prodaných her</p>
      </div>
      <div class="bg-brand-gray rounded-card p-4">
        <div class="flex justify-center gap-0.5 mb-1" aria-label={`${p.hodnoceni} z 5 hvězd`}>
          {Array.from({ length: p.hodnoceni }).map(() => (
            <span class="text-yellow-400 text-xl leading-none">★</span>
          ))}
        </div>
        <p class="text-xs text-brand-gray-dark uppercase tracking-wide">{p.pocetRecenzi} recenzí</p>
      </div>
      <div class="bg-brand-gray rounded-card p-4">
        <p class="font-display text-3xl md:text-4xl text-brand-black">16+</p>
        <p class="text-xs text-brand-gray-dark uppercase tracking-wide mt-1">pro dospělé</p>
      </div>
    </div>

    <h2 class="font-display text-4xl md:text-5xl uppercase text-brand-black text-center mb-8">
      Co říkají ostatní
    </h2>

    <!-- Recenze -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      {reviews.map((review) => (
        <div class="bg-brand-gray rounded-card p-5 border border-gray-200">
          <div class="flex gap-0.5 mb-3" aria-label={`${review.stars} z 5 hvězd`}>
            {Array.from({ length: review.stars }).map(() => (
              <span class="text-yellow-400 text-lg">★</span>
            ))}
          </div>
          <p class="text-brand-black text-sm leading-relaxed mb-4">„{review.text}"</p>
          <p class="text-brand-gray-dark text-xs font-bold">— {review.name}</p>
        </div>
      ))}
    </div>

    <!-- Heureka badge -->
    <div class="flex justify-center">
      <a
        href="https://karetni-hry.heureka.cz/karty-bez-cenzury-karty-proti-lidskosti/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 bg-brand-gray border border-gray-200 rounded-full px-5 py-3 hover:border-gray-400 transition-colors group"
        aria-label="91 % zákazníků doporučuje na Heureka.cz – 27 hodnocení"
      >
        <!-- Heureka oranžová tečka jako jednoduchý brand marker -->
        <span class="w-5 h-5 rounded-full flex-shrink-0" style="background:#f60" aria-hidden="true"></span>
        <span class="text-sm text-brand-black">
          <strong>91 %</strong> zákazníků doporučuje na Heurece
          <span class="text-brand-gray-dark mx-1">·</span>
          <span class="text-brand-gray-dark">27 hodnocení</span>
        </span>
        <span class="text-brand-gray-dark text-xs group-hover:text-brand-black transition-colors">→</span>
      </a>
    </div>
  </div>
</section>
