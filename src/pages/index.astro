---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CardGallery from '../components/CardGallery.astro';
import HowToPlay from '../components/HowToPlay.astro';
import Extension from '../components/Extension.astro';
import Bundle from '../components/Bundle.astro';
import SocialProof from '../components/SocialProof.astro';
import EmailSignup from '../components/EmailSignup.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
---

<Layout
  title="Karty bez cenzury – Karty proti lidskosti v češtině"
  description="Karty proti lidskosti konečně v češtině. Karty bez cenzury jsou sprostá párty hra se 400 kartami černého humoru – česká verze Cards Against Humanity, akorát drzejší."
>
  <Hero />
  <CardGallery />
  <HowToPlay />
  <Extension />
  <Bundle />
  <SocialProof />
  <EmailSignup />
  <FAQ />
  <Footer />
  <CookieConsent />
</Layout>
